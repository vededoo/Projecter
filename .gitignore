# Projecter .gitignore

# PRD (clone séparé via deploy.sh)
Projecter_prd/

# Dépendances
node_modules/

# Variables d'environnement
.env
.env.local

# OS
.DS_Store
**/.DS_Store

# Logs
logs/
*.log

# Build client
client/build/
coverage/

# Storage (données runtime)
storage/uploads/*
storage/generated/*
storage/audio/*
!storage/uploads/.gitkeep
!storage/generated/.gitkeep

# Secrets / tokens runtime — ne JAMAIS committer
**/storage/*token*.json
**/storage/*credentials*.json

# Editeurs
.vscode/
.idea/
